{
  "manifest_version": 3,
  "name": "Screenshot Drop",
  "version": "0.1.0",
  "description": "Capture, annotate, and send screenshots to a LAN destination.",
  "permissions": ["activeTab", "tabs", "scripting", "storage", "clipboardWrite", "notifications"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "commands": {
    "capture-last-mode": {
      "suggested_key": {
        "default": "Ctrl+Shift+S"
      },
      "description": "Capture screenshot (last-used mode)"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
