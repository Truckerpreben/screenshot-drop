SNAPDROP_ADDR=0.0.0.0:9922
SNAPDROP_DIR=/home/hcadmin/screenshots
SNAPDROP_TOKEN=replace-with-output-of-snapdropd--gen-token

# Optional retention (both default to 0 = disabled). Uncomment to enable.
# Delete screenshots older than this many days:
#SNAPDROP_RETAIN_DAYS=30
# Keep at most this many newest screenshots (oldest beyond this are deleted):
#SNAPDROP_RETAIN_MAX=500
